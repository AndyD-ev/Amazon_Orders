{
  "name": "taller_orders",
  "version": "1.0.0",
  "description": "Modulo para el taller de AWS con Serverless hecho para manejar las peticiones de las ordenes",
  "main": "index.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "deploy:dev": "serverless deploy --stage develop --aws-profile serverless_user_personal",
    "remove:dev": "serverless remove --stage develop --aws-profile serverless_user_personal",
    "deploy:prod": "serverless deploy --stage prod --aws-profile serverless_user_personal",
    "remove:prod": "serverless remove --stage prod --aws-profile serverless_user_personal"
  },
  "keywords": [
    "AWS",
    "Node.js",
    "Serverless"
  ],
  "author": "Diana Andrea",
  "license": "ISC",
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^25.7.0",
    "aws-lambda": "^1.0.7",
    "serverless": "^4.34.0",
    "serverless-localstack": "^1.4.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@aws-sdk/client-lambda": "^3.1045.0",
    "@aws-sdk/lib-dynamodb": "^3.1036.0",
    "uuid": "^14.0.0"
  }
}
